# MedTrust Maps — Env vars reference (los valores reales viven en tu .env.local, NO en el repo)
# Copia este archivo a .env.local y rellena con tus keys.

# Insforge backend
NEXT_PUBLIC_INSFORGE_URL=https://<project>.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=<anon-jwt>
NEXT_PUBLIC_INSFORGE_FUNCTIONS_URL=https://<project>.functions.insforge.app

# SERVER-ONLY. Nunca en el cliente ni en el repo.
INSFORGE_API_KEY=<ik_...>

# Mapbox (client-safe, pero restringe por dominio en account.mapbox.com)
NEXT_PUBLIC_MAPBOX_TOKEN=<pk...>

# Terceros (futuros)
# RESEND_API_KEY=
# SENTRY_DSN=
# POSTHOG_KEY=
